# Source, tests, and tooling are not needed at runtime — the bundle ships the
# compiled dist/ plus production node_modules only.
src/
tests/
scripts/
docs/
coverage/
.github/
.git/
.vscode/

# Config / build artifacts
tsconfig*.json
eslint.config.mjs
.eslintrc*
.prettierrc*
*.tsbuildinfo
.env
.env.*

# Dev-only files
CONTRIBUTING.md
CHANGELOG.md
*.test.ts
*.spec.ts

# Trim third-party bloat from bundled dependencies (not needed at runtime).
# package.json and LICENSE files are intentionally kept.
node_modules/**/test/
node_modules/**/tests/
node_modules/**/__tests__/
node_modules/**/*.test.js
node_modules/**/*.map
node_modules/**/docs/
node_modules/**/example/
node_modules/**/examples/
node_modules/**/.github/
node_modules/**/README.md
node_modules/**/readme.md
node_modules/**/*.markdown
node_modules/**/dist-test*/
node_modules/**/benchmark/
node_modules/**/.nyc_output/
